#layout python3 .venv  # this is an improvement over source .venv/bin/activate Note that i have installed the python-is-python3 library and so using python 3 or python would both work.  But to use layout you would need to do this at the start before running uv venv .venv
source .venv/bin/activate

# Project directory - single source of truth (update this if you move the project)
export LOCAL_DIR="/home/nodozi/projects/NEBIUS_MAR_2026/toxic_homework"
export REPO_URL="https://github.com/NnamdiOdozi/toxic_homework.git"
export PROJECT_DIR="\$HOME/toxic_homework"
export RUN_ENV_SETUP="1"

# Propagate LOCAL_DIR to .env.claude for Claude shells (which can't run direnv)
if grep -q "^LOCAL_DIR=" .env.claude 2>/dev/null; then
  sed -i "s|^LOCAL_DIR=.*|LOCAL_DIR=$LOCAL_DIR|" .env.claude
else
  echo "LOCAL_DIR=$LOCAL_DIR" >> .env.claude
fi

dotenv .env
dotenv .env.claude